// This is your Prisma schema file
// Mirrors the existing Supabase PostgreSQL schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?  @map("password_hash")
  fullName     String?  @map("full_name")
  avatarUrl    String?  @map("avatar_url")
  phone        String?
  role         Role     @default(user)
  provider     Provider @default(local)
  providerId   String?  @map("provider_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  assets  Asset[]
  rentals Rental[]

  @@map("users")
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String   @default("")
  icon        String   @default("Package")
  createdAt   DateTime @default(now()) @map("created_at")

  assets Asset[]

  @@map("categories")
}

model Asset {
  id              String      @id @default(uuid())
  name            String
  description     String      @default("")
  imageUrl        String      @default("") @map("image_url")
  make            String?     @map("make")
  model           String?     @map("model")
  year            Int?        @map("year")
  color           String?     @map("color")
  mileage         Int?        @map("mileage")
  transmission    String?     @map("transmission")
  fuelType        String?     @map("fuel_type")
  seats           Int?        @map("seats")
  vehicleClass    String?     @map("vehicle_class")
  cityMpg         Int?        @map("city_mpg")
  highwayMpg      Int?        @map("highway_mpg")
  combinationMpg  Int?        @map("combination_mpg")
  cylinders       Int?        @map("cylinders")
  displacement    Float?      @map("displacement")
  drive           String?     @map("drive")
  // Real estate fields
  propertyType    String?     @map("property_type")
  bedrooms        Int?        @map("bedrooms")
  bathrooms       Float?      @map("bathrooms")
  areaSqft        Int?        @map("area_sqft")
  address         String?     @map("address")
  city            String?     @map("city")
  state           String?     @map("state")
  zipCode         String?     @map("zip_code")
  yearBuilt       Int?        @map("year_built")
  garage          Int?        @map("garage")
  hasPool         Boolean?    @map("has_pool")
  listingStatus   String?     @map("listing_status")
  price           Decimal?    @default(0) @map("price")
  images          String[]    @default([]) @map("images")
  dailyRate       Decimal     @default(0) @map("daily_rate")
  weeklyRate      Decimal     @default(0) @map("weekly_rate")
  monthlyRate     Decimal     @default(0) @map("monthly_rate")
  securityDeposit Decimal     @default(0) @map("security_deposit")
  condition       Condition   @default(good)
  status          AssetStatus @default(available)
  location        String      @default("")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  ownerId    String   @map("owner_id")
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  categoryId String?  @map("category_id")
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  rentals Rental[]

  @@map("assets")
}

model Rental {
  id              String       @id @default(uuid())
  startDate       DateTime     @map("start_date")
  endDate         DateTime     @map("end_date")
  totalPrice      Decimal      @default(0) @map("total_price")
  securityDeposit Decimal      @default(0) @map("security_deposit")
  status          RentalStatus @default(pending)
  notes           String       @default("")
  // snapshot fields for rentals that don't reference a persisted Asset
  snapshotTitle    String?     @map("snapshot_title")
  snapshotImageUrl String?     @map("snapshot_image_url")
  snapshotOwnerName String?    @map("snapshot_owner_name")
  snapshotOwnerEmail String?   @map("snapshot_owner_email")
  snapshotOwnerPhone String?   @map("snapshot_owner_phone")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  assetId  String? @map("asset_id")
  asset    Asset?  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  renterId String @map("renter_id")
  renter   User   @relation(fields: [renterId], references: [id], onDelete: Cascade)

  @@map("rentals")
}

enum Role {
  user
  admin
}

enum Provider {
  local
  google
  github
}

enum Condition {
  excellent
  good
  fair
  poor
}

enum AssetStatus {
  pending
  available
  rented
  maintenance
  retired
}

enum RentalStatus {
  pending
  active
  completed
  cancelled
}
